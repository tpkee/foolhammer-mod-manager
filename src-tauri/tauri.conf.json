{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Foolhammer Mod Manager",
  "version": "0.1.0",
  "identifier": "com.tpkee.foolhammer-mod-manager",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "nuxt dev",
    "beforeBuildCommand": "nuxt generate"
  },
  "app": {
    "windows": [
      {
        "title": "Foolhammer Mod Manager",
        "width": 1080,
        "height": 864,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**/.local/share/**/"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
